#include <iostream>
#include <vector>
#include <queue>
 
using namespace std;
 
int main() {
    // Оптимизация ввода-вывода для ускорения работы программы
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
 
    int n, m, k;
    if (!(cin >> n >> m >> k)) return 0;
 
    vector<vector<int>> adj(n + 1);
    for (int i = 0; i < m; ++i) {
        int u, v;
        cin >> u >> v;
        adj[u].push_back(v);
        adj[v].push_back(u); // Граф неориентированный
    }
 
    vector<int> dist(n + 1, -1);
    dist[k] = 0; // Расстояние до стартовой вершины равно 0
 
    queue<int> q;
    q.push(k);
 
    while (!q.empty()) {
        int u = q.front();
        q.pop();
 
        for (int v : adj[u]) {
            if (dist[v] == -1) {
                dist[v] = dist[u] + 1;
                q.push(v);
            }
        }
    }
 
    for (int i = 1; i <= n; ++i) {
        cout << dist[i] << (i == n ? "" : " ");
    }
    cout << "\n";
 
    return 0;
}
